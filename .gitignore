# ─── Pipeline inputs (user-supplied or downloaded, too large for git) ────────
# Cohort BAMs live in bamfiles/<cohort>/ (see config/config.yaml -> cohorts:).
bamfiles/*/*.bam
bamfiles/*/*.bam.bai
hs1.fa
hs1.fa.fai

# Annotation resources are fetched/regenerated locally (see README) — some
# exceed GitHub's file size limit (e.g. repeats.final.bed is ~135 MB).
resources/*
!resources/.gitkeep

# ─── Pipeline outputs ─────────────────────────────────────────────────────────
# results/<cohort>/... plus the pooled results/_public_reference/ master list.
results/

# ─── Snakemake run state ──────────────────────────────────────────────────────
.snakemake/

# ─── R ─────────────────────────────────────────────────────────────────────
.Rhistory
.RData
.Rproj.user/

# ─── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc

# ─── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
*.swp

# ─── Local tool config (machine-specific, not project source) ───────────────
.claude/
